{
    "name": "clusta",
    "version": "1.0.0",
    "license": "GPLv3",
    "type": "module",
    "main": "dist/main/main.js",
    "scripts": {
        "dev": "npm run ts & concurrently \"npm run render-dev\" \"electron . \"",
        "build": "npm run ts && npm run render-prod && electron .",
        "ts": "tsc -p src/tsconfig.json && tsc-alias -p src/tsconfig.json && tsc -p src/preload/tsconfig.json",
        "start": "vite --config src/render/vite.config.js build && electron .",
        "test": "npx vitest",
        "pretty": "prettier --write \"./**/*.{js,jsx,mjs,cjs,ts,tsx,json}\"",
        "render-prod": "vite build --config src/render/vite.config.js",
        "render-dev": "vite --config src/render/vite.config.js",
        "build-win": "npm run ts && npm run render-prod && electron-builder --win"
    },
    "build": {
        "appId": "com.astrofoxlabs.clusta",
        "productName": "Clusta",
        "files": [
            "dist/**/*",
            "package.json",
            "assets/**/*",
            "!**/*.map",
            "!**/test",
            "!**/*.md"
        ],
        "compression": "maximum",
        "directories": {
            "buildResources": "assets",
            "output": "release"
        },
        "mac": {
            "target": "dmg"
        },
        "win": {
            "target": "nsis"
        },
        "linux": {
            "target": "AppImage"
        },
        "publish": {
            "provider": "github",
            "owner": "astrofoxlabs",
            "repo": "clusta"
        }
    },
    "prettier": {
        "semi": true,
        "singleQuote": true,
        "trailingComma": "all",
        "printWidth": 120,
        "tabWidth": 4
    },
    "devDependencies": {
        "@preact/preset-vite": "^2.10.2",
        "@types/react": "^19.2.9",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-vue": "^6.0.3",
        "dotenv": "^17.2.3",
        "electron": "^39.2.2",
        "electron-builder": "^26.8.1",
        "electron-updater": "^6.8.3",
        "prettier": "^3.8.1",
        "sass-embedded": "^1.96.0",
        "tsc-alias": "^1.8.16",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    },
    "dependencies": {
        "@excalidraw/excalidraw": "^0.18",
        "@vscode/codicons": "^0.0.44",
        "concurrently": "^9.2.1",
        "electron-log": "^5.4.3",
        "file-type": "^21.3.0",
        "fuse.js": "^7.1.0",
        "pinia": "^3.0.4",
        "preact": "^10.28.2",
        "sharp": "^0.34.5",
        "sqlite3": "^5.0.2",
        "vite": "^7.2.7",
        "vue": "^3.5.25",
        "vue-router": "^4.6.4"
    }
}
